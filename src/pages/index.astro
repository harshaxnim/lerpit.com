---
import LerpetteLessonPage from '../components/LerpetteLessonPage.astro';
import { getCollections, getIssueZeroLerpette } from '../lib/lerpettes/content';

const issueZero = await getIssueZeroLerpette();
const collections = await getCollections();
const otherLerpettes = collections.flatMap((collection) => collection.mixtapes);
---

<LerpetteLessonPage mixtape={issueZero} allMixtapes={otherLerpettes} />
