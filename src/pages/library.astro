---
import CollectionShowcase from '../components/CollectionShowcase.astro';
import SiteHeader from '../components/SiteHeader.astro';
import BaseLayout from '../layouts/BaseLayout.astro';
import { getCollections } from '../lib/lerpettes/content';

const collections = await getCollections();
---

<BaseLayout title="Lerpettes · Lerpit" description="Document-first lerpettes grouped by collection and mixtape.">
  <main class="site-shell">
    <section class="lerpette-player">
      <SiteHeader />
      <header class="collection-header">
        <h2>The lerpette library</h2>
        <p>
          Lerpettes grouped by collections.
        </p>
      </header>
      <hr class="library-separator" />
      {collections.map((collection) => (
        <CollectionShowcase collection={collection} showLink={true} />
      ))}
    </section>
  </main>
</BaseLayout>
