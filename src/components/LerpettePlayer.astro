---
import type { LerpetteMixtape } from '../lib/lerpettes/types';

interface Props {
  lerpette: LerpetteMixtape;
  playerLabel: string;
  headerTitle?: string;
  headerSubtitle?: string;
}

const { lerpette, playerLabel, headerTitle, headerSubtitle } = Astro.props as Props;
const playerId = `lerpette-${(lerpette.collectionSlug ? `${lerpette.collectionSlug}-${lerpette.slug}` : lerpette.slug)
  .replace(/[^a-z0-9-]/gi, '-')
  .toLowerCase()}`;
const displayTitle = headerTitle ?? lerpette.title;
const displaySubtitle = headerSubtitle ?? playerLabel;
const clientSteps = lerpette.steps.map((step) => ({
  id: step.id,
  title: step.title,
  runtimeImportKey: step.runtimeImportKey,
  assetBasePath: step.assetBasePath
}));
const playerConfig = JSON.stringify({ playerId, steps: clientSteps });
---

<section class="lerpette-player" data-lerpette-player>
  <script type="application/json" data-player-config set:html={playerConfig}></script>
  <div class="lerpette-player__bar">
    <div>
      <h1>{displayTitle}</h1>
      <p class="lerpette-player__subtitle">{displaySubtitle}</p>
    </div>
  </div>

  <div class="lerpette-player__grid">
    <nav class="lerpette-player__rail" aria-label="Sections rail">
      <p class="eyebrow lerpette-player__label">Sections</p>

      <ol class="lerpette-player__chapters">
        <li>
          <a
            class="lerpette-player__chapter"
            href={`#${playerId}-intro`}
            data-target-id="intro"
            aria-label={`Jump to ${lerpette.title}`}
          >
            <span class="lerpette-player__chapter-index">00</span>
            <span>{lerpette.title}</span>
          </a>
        </li>
        {lerpette.steps.map((step, index) => (
          <li>
            <a
              class="lerpette-player__chapter"
              href={`#${playerId}-${step.id}`}
              data-target-id={step.id}
              aria-label={`Jump to ${step.title}`}
            >
              <span class="lerpette-player__chapter-index">{String(index + 1).padStart(2, '0')}</span>
              <span>{step.title}</span>
            </a>
          </li>
        ))}
      </ol>
    </nav>

    <div class="lerpette-player__lesson">
      <section class="lerpette-intro" id={`${playerId}-intro`} data-section-id="intro">
        <h2 class="lerpette-intro__title">{lerpette.title}</h2>
        <p class="lerpette-intro__summary">{lerpette.summary}</p>
        <div class="prose-block" set:html={lerpette.introHtml}></div>
      </section>

      {lerpette.steps.map((step, index) => (
        <section
          class="lerpette-step"
          id={`${playerId}-${step.id}`}
          data-section-id={step.id}
          aria-labelledby={`${playerId}-${step.id}-title`}
        >
          <div class="lerpette-step__header">
            <span class="lerpette-step__index">{String(index + 1).padStart(2, '0')}</span>
            <h2 id={`${playerId}-${step.id}-title`}>{step.title}</h2>
          </div>
          <div class="prose-block" set:html={step.bodyHtml}></div>
        </section>
      ))}
    </div>

    <aside class="lerpette-stage">
      <button
        class="lerpette-stage__toggle"
        type="button"
        data-stage-toggle
        aria-expanded="false"
        aria-controls={`${playerId}-viewport-surface`}
        aria-label="Show viewport"
      >
        <span class="lerpette-stage__toggle-arrow" data-stage-toggle-arrow aria-hidden="true">◀</span>
        <span class="lerpette-stage__toggle-text">VIEWPORT</span>
        <span class="lerpette-stage__toggle-arrow" data-stage-toggle-arrow aria-hidden="true">◀</span>
      </button>
      <p class="eyebrow lerpette-stage__label">Viewport</p>
      <div class="lerpette-stage__canvas" data-stage-host id={`${playerId}-viewport-surface`}>
        <canvas data-stage-canvas aria-label={`Live render for ${lerpette.title}`}></canvas>
      </div>
    </aside>
  </div>
</section>

<script>
  import { initLerpettePlayers } from '../lib/lerpettes/playerClient';

  initLerpettePlayers();
</script>
